{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "album",
  "compatibility_date": "2026-06-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git/**",
      "node_modules/**"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
